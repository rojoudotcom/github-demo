{
  "name": "github-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A vanilla HTML/CSS/JS task board that demonstrates the GitHub Flow: branch, PR, CI, merge, and deploy to GitHub Pages.",
  "scripts": {
    "serve": "node scripts/serve.mjs",
    "test": "node --test test/unit/*.test.js",
    "test:e2e": "playwright test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3"
  }
}
